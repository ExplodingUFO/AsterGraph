<UserControl
    x:Class="AsterGraph.Wpf.Controls.GraphEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    DataContext="{Binding RelativeSource={RelativeSource Self}}">
  <Grid Background="White">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Padding="12" BorderBrush="#DDE0E6" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal">
        <Button Content="Save" Command="{Binding Editor.SaveCommand}" Margin="0,0,8,0" />
        <Button Content="Load" Command="{Binding Editor.LoadCommand}" Margin="0,0,8,0" />
        <Button Content="Undo" Command="{Binding Editor.UndoCommand}" Margin="0,0,8,0" />
        <Button Content="Redo" Command="{Binding Editor.RedoCommand}" Margin="0,0,8,0" />
        <Button Content="Delete" Command="{Binding Editor.DeleteSelectionCommand}" Margin="0,0,8,0" />
        <Button Content="Copy" Command="{Binding Editor.CopySelectionCommand}" Margin="0,0,8,0" />
        <Button Content="Paste" Command="{Binding Editor.PasteCommand}" Margin="0,0,8,0" />
        <Button Content="Fit" Command="{Binding Editor.FitViewCommand}" Margin="0,0,8,0" />
        <Button Content="Reset View" Command="{Binding Editor.ResetViewCommand}" Margin="0,0,8,0" />
        <Button Content="Export Selection"
                Command="{Binding Editor.ExportSelectionFragmentCommand}"
                Margin="0,0,8,0" />
        <Button Content="Import Fragment"
                Command="{Binding Editor.ImportFragmentCommand}" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" Margin="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="280" />
        <ColumnDefinition Width="3*" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>
      <Border Padding="10" BorderBrush="#DDE0E6" BorderThickness="1" Margin="0,0,8,0">
        <DockPanel>
          <TextBlock Text="Node Templates" FontWeight="SemiBold" Margin="0,0,0,8" />
          <ListView ItemsSource="{Binding Editor.NodeTemplates}" BorderThickness="0">
            <ListView.ItemTemplate>
              <DataTemplate>
                <DockPanel LastChildFill="False" Margin="0,0,0,8">
                  <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#5A6474" />
                    <TextBlock Text="{Binding PortSummary}" FontSize="10" Foreground="#666F7F" />
                  </StackPanel>
                  <Button DockPanel.Dock="Right"
                          Content="Add"
                          Margin="8,0,0,0"
                          MinWidth="56"
                          Command="{Binding DataContext.Editor.AddNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}" />
                </DockPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </DockPanel>
      </Border>

      <Border Grid.Column="1" Padding="10" BorderBrush="#DDE0E6" BorderThickness="1" Margin="0,0,8,0">
        <DockPanel>
          <TextBlock Text="Nodes" FontWeight="SemiBold" Margin="0,0,0,8" />
          <ListView ItemsSource="{Binding Editor.Nodes}" BorderThickness="0">
            <ListView.View>
              <GridView>
                <GridViewColumn Width="180" DisplayMemberBinding="{Binding Title}" Header="Title" />
                <GridViewColumn Width="240" DisplayMemberBinding="{Binding Subtitle}" Header="Subtitle" />
              </GridView>
            </ListView.View>
          </ListView>
        </DockPanel>
      </Border>

      <Border Grid.Column="2" Padding="10" BorderBrush="#DDE0E6" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="Inspector Summary" FontWeight="SemiBold" Margin="0,0,0,8" />
          <TextBlock Text="{Binding Editor.InspectorTitle}" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Editor.InspectorCategory}" Margin="0,8,0,0" />
          <TextBlock Text="{Binding Editor.InspectorDescription}" Margin="0,8,0,0" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Editor.SelectionCaption}" Margin="0,8,0,0" />
          <Separator Margin="0,10,0,10" />
          <TextBlock Text="Inputs" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Editor.InspectorInputs}" TextWrapping="Wrap" Margin="0,4,0,0" />
          <TextBlock Text="Outputs" FontWeight="SemiBold" Margin="0,8,0,0" />
          <TextBlock Text="{Binding Editor.InspectorOutputs}" TextWrapping="Wrap" Margin="0,4,0,0" />
          <TextBlock Text="Connections" FontWeight="SemiBold" Margin="0,8,0,0" />
          <TextBlock Text="{Binding Editor.InspectorConnections}" TextWrapping="Wrap" Margin="0,4,0,0" />
          <TextBlock Text="Upstream" FontWeight="SemiBold" Margin="0,8,0,0" />
          <TextBlock Text="{Binding Editor.InspectorUpstream}" TextWrapping="Wrap" Margin="0,4,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Padding="12" BorderBrush="#DDE0E6" BorderThickness="1,1,1,0" Background="#F7F8FA">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1*" />
          <ColumnDefinition Width="1*" />
          <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding Editor.ModeCaption}" FontSize="12" TextWrapping="Wrap" />
        <TextBlock Grid.Column="1" Text="{Binding Editor.StatsCaption}" FontSize="12" TextWrapping="Wrap" />
        <TextBlock Grid.Column="2"
                   Text="{Binding Editor.StatusMessage}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
