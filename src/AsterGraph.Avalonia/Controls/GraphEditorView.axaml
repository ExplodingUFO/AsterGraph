<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AsterGraph.Avalonia.Controls"
             x:Class="AsterGraph.Avalonia.Controls.GraphEditorView"
             x:Name="Root"
             Focusable="True">
  <UserControl.Styles>
    <Style Selector="Button.astergraph-toolbar-action">
      <Setter Property="Margin" Value="{DynamicResource AsterGraph.ToolbarButtonMargin}" />
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.ToolbarButtonPadding}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.ToolbarButtonCornerRadius}" />
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AsterGraph.HeadlineBrush}" />
      <Setter Property="FontSize" Value="{DynamicResource AsterGraph.InspectorBodyFontSize}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.astergraph-template-card">
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.TemplateCardPadding}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.TemplateCardCornerRadius}" />
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AsterGraph.BodyBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.astergraph-pill">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.PillCornerRadius}" />
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.PillPadding}" />
    </Style>

    <Style Selector="Border.astergraph-inspector-section">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.InspectorSectionCornerRadius}" />
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.InspectorSectionPadding}" />
    </Style>

    <Style Selector="TextBox.astergraph-input">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputBorderBrush}" />
    </Style>

    <Style Selector="ComboBox.astergraph-input">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputBorderBrush}" />
    </Style>
  </UserControl.Styles>
  <Border Background="{DynamicResource AsterGraph.ShellBackgroundBrush}"
          Padding="{DynamicResource AsterGraph.ShellPadding}"
          DataContext="{Binding Editor, ElementName=Root}">
    <Grid x:Name="PART_ShellGrid"
          RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="Auto,*,Auto"
          RowSpacing="{DynamicResource AsterGraph.DefaultSpacing}"
          ColumnSpacing="{DynamicResource AsterGraph.DefaultSpacing}">
      <Border x:Name="PART_HeaderChrome"
              Grid.ColumnSpan="3"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="20">
        <StackPanel Spacing="14">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="节点图 SDK 演示台"
                         FontSize="12"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding Title}"
                         FontSize="24"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
              <TextBlock Text="{Binding Description}"
                         FontSize="16"
                         MaxWidth="820"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>

            <StackPanel x:Name="PART_HeaderBadges"
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Spacing="8">
              <Border Classes="astergraph-pill">
                <TextBlock Text="{Binding StatsCaption}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
              </Border>
              <Border Classes="astergraph-pill">
                <TextBlock Text="{Binding ModeCaption}"
                           FontSize="12"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
            </StackPanel>
          </Grid>

          <WrapPanel x:Name="PART_HeaderToolbar"
                     Orientation="Horizontal"
                     ItemHeight="40"
                     ItemWidth="120" />
          <WrapPanel x:Name="PART_CompositeWorkflowToolbar"
                     Orientation="Horizontal"
                     ItemHeight="40"
                     ItemWidth="180" />
          <WrapPanel x:Name="PART_ScopeBreadcrumbs"
                     Orientation="Horizontal" />
          <Button x:Name="PART_OpenCommandPaletteButton"
                  Classes="astergraph-toolbar-action"
                  HorizontalAlignment="Left"
                  Content="Command Palette" />
        </StackPanel>
      </Border>

      <Border x:Name="PART_LibraryChrome"
              Grid.Row="1"
              Width="{DynamicResource AsterGraph.LibraryPanelWidth}"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.SidePanelPadding}">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="14">
          <StackPanel Spacing="4">
            <TextBlock Text="节点库"
                       FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
            <TextBlock Text="单击卡片可在当前视口中心附近插入节点。"
                       FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            <TextBlock Text="这里只展示可插入节点；命令面板负责动作，片段库负责复用片段。"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AsterGraph.HighlightBrush}" />
          </StackPanel>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="PART_StencilCardList" />
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Grid.Column="1"
              MinHeight="0"
              Background="{DynamicResource AsterGraph.CanvasFrameBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.CanvasFramePadding}">
        <controls:NodeCanvas x:Name="PART_NodeCanvas"
                             VerticalAlignment="Stretch"
                             HorizontalAlignment="Stretch"
                             ViewModel="{Binding}" />
      </Border>

      <Border x:Name="PART_InspectorChrome"
              Grid.Row="1"
              Grid.Column="2"
              Width="{DynamicResource AsterGraph.InspectorPanelWidth}"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.InspectorPanelPadding}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="18">
            <controls:GraphInspectorView x:Name="PART_InspectorSurface"
                                         Editor="{Binding}" />

            <Border Classes="astergraph-inspector-section">
              <StackPanel Spacing="8">
                <TextBlock Text="工作区"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <TextBlock Text="{Binding WorkspaceCaption}"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </StackPanel>
            </Border>

            <Border Classes="astergraph-inspector-section">
              <StackPanel Spacing="8">
                <TextBlock Text="片段"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <TextBlock Text="{Binding FragmentCaption}"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                <TextBlock Text="{Binding FragmentStatusCaption}"
                           FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <WrapPanel Orientation="Horizontal">
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ExportSelectionFragmentCommand}"
                          Content="导出片段" />
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ImportFragmentCommand}"
                          Content="导入片段" />
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ClearFragmentCommand}"
                          Content="清空片段" />
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ExportSelectionAsTemplateCommand}"
                          Content="另存为模板" />
                </WrapPanel>
                <TextBlock Text="{Binding FragmentLibraryCaption}"
                           FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <ComboBox ItemsSource="{Binding FragmentTemplates}"
                          SelectedItem="{Binding SelectedFragmentTemplate}"
                          DisplayMemberBinding="{Binding Name}"
                          Classes="astergraph-input"
                          IsVisible="{Binding BehaviorOptions.Fragments.EnableFragmentLibrary}" />
                <WrapPanel Orientation="Horizontal"
                           IsVisible="{Binding BehaviorOptions.Fragments.EnableFragmentLibrary}">
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding RefreshFragmentTemplatesCommand}"
                          Content="刷新模板" />
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ImportSelectedTemplateCommand}"
                          Content="导入模板" />
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding DeleteSelectedTemplateCommand}"
                          Content="删除模板" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Classes="astergraph-inspector-section"
                    IsVisible="{Binding BehaviorOptions.View.ShowMiniMap}">
              <StackPanel Spacing="8">
                <TextBlock Text="迷你地图"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <controls:GraphMiniMap x:Name="PART_MiniMapSurface"
                                       Height="168"
                                       Session="{Binding Session}"
                                       StyleOptions="{Binding StyleOptions}" />
              </StackPanel>
            </Border>

            <StackPanel Spacing="8">
              <TextBlock Text="快捷键"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="在空白画布上按住左键拖拽：框选多个节点"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="右键单击多选结果：打开包含对齐与分布工具的批量菜单"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Demo 宿主在拖拽期间可选启用网格吸附与对齐辅助线"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <StackPanel x:Name="PART_ShortcutHelpList"
                          Spacing="8" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Border x:Name="PART_StatusChrome"
              Grid.Row="2"
              Grid.ColumnSpan="3"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.StatusPanelPadding}">
        <Grid ColumnDefinitions="2*,2*,3*"
              ColumnSpacing="18">
          <TextBlock Text="{Binding ModeCaption}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource AsterGraph.BodyBrush}" />
          <TextBlock Grid.Column="1"
                     Text="{Binding StatsCaption}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource AsterGraph.BodyBrush}" />
          <TextBlock Grid.Column="2"
                     Text="{Binding StatusMessage}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
        </Grid>
      </Border>

      <Border x:Name="PART_CommandPaletteChrome"
              Grid.ColumnSpan="3"
              Grid.RowSpan="3"
              Width="520"
              Margin="0,52,0,0"
              Padding="18"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              IsVisible="False"
              ZIndex="20">
        <StackPanel Spacing="12">
          <TextBlock Text="Command Palette"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
          <TextBox x:Name="PART_CommandPaletteSearchBox"
                   Watermark="Search commands"
                   Classes="astergraph-input" />
          <ScrollViewer MaxHeight="360"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="PART_CommandPaletteItems"
                        Spacing="8" />
          </ScrollViewer>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>
