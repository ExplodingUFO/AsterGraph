<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AsterGraph.Avalonia.Controls"
             xmlns:viewModels="using:AsterGraph.Editor.ViewModels"
             x:Class="AsterGraph.Avalonia.Controls.GraphEditorView"
             x:Name="Root"
             Focusable="True">
  <UserControl.Styles>
    <Style Selector="Button.astergraph-toolbar-action">
      <Setter Property="Margin" Value="{DynamicResource AsterGraph.ToolbarButtonMargin}" />
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.ToolbarButtonPadding}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.ToolbarButtonCornerRadius}" />
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AsterGraph.HeadlineBrush}" />
      <Setter Property="FontSize" Value="{DynamicResource AsterGraph.InspectorBodyFontSize}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.astergraph-template-card">
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.TemplateCardPadding}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.TemplateCardCornerRadius}" />
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AsterGraph.BodyBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.astergraph-pill">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.PillCornerRadius}" />
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.PillPadding}" />
    </Style>

    <Style Selector="Border.astergraph-inspector-section">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.InspectorSectionCornerRadius}" />
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.InspectorSectionPadding}" />
    </Style>

    <Style Selector="TextBox.astergraph-input">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputBorderBrush}" />
    </Style>

    <Style Selector="ComboBox.astergraph-input">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputBorderBrush}" />
    </Style>
  </UserControl.Styles>
  <Border Background="{DynamicResource AsterGraph.ShellBackgroundBrush}"
          Padding="{DynamicResource AsterGraph.ShellPadding}"
          DataContext="{Binding Editor, ElementName=Root}">
    <Grid RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="Auto,*,Auto"
          RowSpacing="{DynamicResource AsterGraph.DefaultSpacing}"
          ColumnSpacing="{DynamicResource AsterGraph.DefaultSpacing}">
      <Border Grid.ColumnSpan="3"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.HeroPanelPadding}">
        <Grid RowDefinitions="Auto,Auto"
              RowSpacing="18">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="20">
            <StackPanel Spacing="6">
              <TextBlock Text="NODE GRAPH PRODUCT DEMO"
                         FontSize="{DynamicResource AsterGraph.ShellEyebrowFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding Title}"
                         FontSize="{DynamicResource AsterGraph.ShellTitleFontSize}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
              <TextBlock Text="{Binding Description}"
                         FontSize="{DynamicResource AsterGraph.ShellBodyFontSize}"
                         MaxWidth="960"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        Spacing="8">
              <Border Classes="astergraph-pill">
                <TextBlock Text="{Binding StatsCaption}"
                           FontSize="{DynamicResource AsterGraph.ShellEyebrowFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
              </Border>
              <Border Classes="astergraph-pill">
                <TextBlock Text="{Binding ModeCaption}"
                           FontSize="{DynamicResource AsterGraph.ShellEyebrowFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
            </StackPanel>
          </Grid>

          <WrapPanel Orientation="Horizontal">
            <Button Classes="astergraph-toolbar-action"
                    Command="{Binding SaveCommand}"
                    Content="Save Snapshot" />
            <Button Classes="astergraph-toolbar-action"
                    Command="{Binding LoadCommand}"
                    Content="Load Snapshot" />
            <Button Classes="astergraph-toolbar-action"
                    Command="{Binding UndoCommand}"
                    Content="Undo" />
            <Button Classes="astergraph-toolbar-action"
                    Command="{Binding RedoCommand}"
                    Content="Redo" />
            <Button Classes="astergraph-toolbar-action"
                    Command="{Binding FitViewCommand}"
                    Content="Fit View" />
            <Button Classes="astergraph-toolbar-action"
                    Command="{Binding ResetViewCommand}"
                    Content="Reset View" />
            <Button Classes="astergraph-toolbar-action"
                    Command="{Binding DeleteSelectionCommand}"
                    Content="Delete Selected" />
          </WrapPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Width="{DynamicResource AsterGraph.LibraryPanelWidth}"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.SidePanelPadding}">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="14">
          <StackPanel Spacing="4">
            <TextBlock Text="Node Library"
                       FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
            <TextBlock Text="Click a card to insert a node near the current viewport center."
                       FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AsterGraph.BodyBrush}" />
          </StackPanel>

          <ScrollViewer Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding NodeTemplates}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="viewModels:NodeTemplateViewModel">
                  <Button Classes="astergraph-template-card"
                          Margin="0,0,0,12"
                          Command="{Binding Editor.AddNodeCommand, ElementName=Root}"
                          CommandParameter="{Binding}">
                    <StackPanel Spacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Category}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                        <TextBlock Text="{Binding Title}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                        <TextBlock Text="{Binding Subtitle}"
                                   FontSize="11"
                                   Foreground="{DynamicResource AsterGraph.HighlightBrush}" />
                      </StackPanel>
                      <TextBlock Text="{Binding Description}"
                                 FontSize="12"
                                 TextWrapping="Wrap"
                                 Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                      <Border Classes="astergraph-pill"
                              HorizontalAlignment="Left">
                        <TextBlock Text="{Binding PortSummary}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                      </Border>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Grid.Column="1"
              Background="{DynamicResource AsterGraph.CanvasFrameBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.CanvasFramePadding}">
        <controls:NodeCanvas x:Name="PART_NodeCanvas"
                             ViewModel="{Binding}" />
      </Border>

      <Border Grid.Row="1"
              Grid.Column="2"
              Width="{DynamicResource AsterGraph.InspectorPanelWidth}"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.InspectorPanelPadding}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="Inspector"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding InspectorTitle}"
                         FontSize="{DynamicResource AsterGraph.InspectorTitleFontSize}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
              <TextBlock Text="{Binding InspectorCategory}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.HighlightBrush}" />
              <TextBlock Text="{Binding SelectionCaption}"
                         FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding InspectorDescription}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>

            <Border Classes="astergraph-inspector-section">
              <StackPanel Spacing="{DynamicResource AsterGraph.InspectorSectionSpacing}">
                <StackPanel Spacing="4">
                  <TextBlock Text="Connections"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                  <TextBlock Text="{Binding InspectorConnections}"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                </StackPanel>
                <StackPanel Spacing="4">
                  <TextBlock Text="Inputs"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                  <TextBlock Text="{Binding InspectorInputs}"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                </StackPanel>
                <StackPanel Spacing="4">
                  <TextBlock Text="Outputs"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                  <TextBlock Text="{Binding InspectorOutputs}"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Classes="astergraph-inspector-section">
              <StackPanel Spacing="{DynamicResource AsterGraph.InspectorSectionSpacing}">
                <StackPanel Spacing="4">
                  <TextBlock Text="Upstream"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                  <TextBlock Text="{Binding InspectorUpstream}"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                </StackPanel>
                <StackPanel Spacing="4">
                  <TextBlock Text="Downstream"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                  <TextBlock Text="{Binding InspectorDownstream}"
                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Classes="astergraph-inspector-section">
              <StackPanel Spacing="8">
                <TextBlock Text="Workspace"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <TextBlock Text="{Binding WorkspaceCaption}"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </StackPanel>
            </Border>

            <Border Classes="astergraph-inspector-section">
              <StackPanel Spacing="8">
                <TextBlock Text="Fragments"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <TextBlock Text="{Binding FragmentCaption}"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                <TextBlock Text="{Binding FragmentStatusCaption}"
                           FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <WrapPanel Orientation="Horizontal">
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ExportSelectionFragmentCommand}"
                          Content="Export Fragment" />
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ImportFragmentCommand}"
                          Content="Import Fragment" />
                  <Button Classes="astergraph-toolbar-action"
                          Command="{Binding ClearFragmentCommand}"
                          Content="Clear Fragment" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <Border Classes="astergraph-inspector-section">
              <StackPanel Spacing="8">
                <TextBlock Text="Mini Map"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                <controls:GraphMiniMap Height="168"
                                       ViewModel="{Binding}" />
              </StackPanel>
            </Border>

            <Border Classes="astergraph-inspector-section"
                    IsVisible="{Binding HasAnyEditableParameters, Mode=OneWay}">
              <StackPanel Spacing="{DynamicResource AsterGraph.InspectorSectionSpacing}">
                <TextBlock Text="Parameters"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />

                <ItemsControl ItemsSource="{Binding SelectedNodeParameters}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:NodeParameterViewModel">
                    <Border Background="{DynamicResource AsterGraph.InspectorCardBrush}"
                              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
                              BorderThickness="1"
                              CornerRadius="{DynamicResource AsterGraph.InspectorCardCornerRadius}"
                              Padding="12"
                              Margin="0,0,0,8">
                        <StackPanel Spacing="8">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                            <TextBlock Text="{Binding Description}"
                                       FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                          </StackPanel>

                          <TextBox Text="{Binding StringValue}"
                                   Classes="astergraph-input"
                                   IsVisible="{Binding UsesTextInput}"
                                   IsReadOnly="{Binding IsReadOnly}"
                                   Watermark="{Binding MixedValueHint}" />

                          <CheckBox Content="{Binding BooleanCaption}"
                                    IsVisible="{Binding IsBoolean}"
                                    IsThreeState="True"
                                    IsChecked="{Binding BoolValue}"
                                    IsEnabled="{Binding CanEdit}" />

                          <ComboBox ItemsSource="{Binding Options}"
                                    Classes="astergraph-input"
                                    SelectedItem="{Binding SelectedOption}"
                                    IsVisible="{Binding IsEnum}"
                                    IsEnabled="{Binding CanEdit}" />

                          <TextBlock Text="Multiple values"
                                     IsVisible="{Binding HasMixedValues}"
                                     FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                     Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />

                          <TextBlock Text="{Binding ValidationMessage}"
                                     IsVisible="{Binding HasValidationError}"
                                     FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                     Foreground="{DynamicResource AsterGraph.ValidationErrorBrush}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <StackPanel Spacing="8">
              <TextBlock Text="Shortcuts"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Left-drag on empty canvas: marquee-select nodes"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Ctrl+S / Ctrl+O: save or load snapshot"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Ctrl+Z / Ctrl+Y: undo or redo graph edits"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Right-click on a multi-selection: batch menu with align/distribute tools"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Ctrl+C / Ctrl+V: copy and paste the current selection through the system clipboard"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Demo host enables optional grid snap and alignment guides while dragging"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
              <Border Classes="astergraph-inspector-section">
                <TextBlock Text="Delete / Escape: remove selection or cancel pending connection"
                           FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
              </Border>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Border Grid.Row="2"
              Grid.ColumnSpan="3"
              Background="{DynamicResource AsterGraph.PanelBrush}"
              BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
              BorderThickness="1"
              CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
              Padding="{DynamicResource AsterGraph.StatusPanelPadding}">
        <Grid ColumnDefinitions="2*,2*,3*"
              ColumnSpacing="18">
          <TextBlock Text="{Binding ModeCaption}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource AsterGraph.BodyBrush}" />
          <TextBlock Grid.Column="1"
                     Text="{Binding StatsCaption}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource AsterGraph.BodyBrush}" />
          <TextBlock Grid.Column="2"
                     Text="{Binding StatusMessage}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
