<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:AsterGraph.Avalonia.Controls"
             xmlns:viewModels="using:AsterGraph.Editor.ViewModels"
             x:Class="AsterGraph.Avalonia.Controls.GraphInspectorView"
             x:Name="Root">
  <UserControl.Styles>
    <Style Selector="Border.astergraph-inspector-section">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.InspectorSectionCornerRadius}" />
      <Setter Property="Padding" Value="{DynamicResource AsterGraph.InspectorSectionPadding}" />
    </Style>

    <Style Selector="Border.astergraph-parameter-card">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InspectorCardBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.ParameterCardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.InspectorCardCornerRadius}" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Border.astergraph-parameter-group-header">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InspectorCardBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.InspectorCardCornerRadius}" />
      <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style Selector="Border.astergraph-parameter-guidance">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.BadgeBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.PillCornerRadius}" />
      <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="TextBox.astergraph-input">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="10,6" />
    </Style>

    <Style Selector="ComboBox.astergraph-input">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputBorderBrush}" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style Selector="TextBox.astergraph-input:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputFocusBorderBrush}" />
    </Style>

    <Style Selector="ComboBox.astergraph-input:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AsterGraph.InputFocusBorderBrush}" />
    </Style>

    <Style Selector="CheckBox.astergraph-input">
      <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style Selector="Button.astergraph-group-toggle">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style Selector="Button.astergraph-reset-parameter-button">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style Selector="Border.astergraph-parameter-state-pill">
      <Setter Property="Background" Value="{DynamicResource AsterGraph.ParameterStateBadgeBrush}" />
      <Setter Property="CornerRadius" Value="{DynamicResource AsterGraph.PillCornerRadius}" />
      <Setter Property="Padding" Value="8,2" />
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource AsterGraph.PanelBrush}"
          BorderBrush="{DynamicResource AsterGraph.PanelBorderBrush}"
          BorderThickness="1"
          CornerRadius="{DynamicResource AsterGraph.DefaultCornerRadius}"
          Padding="{DynamicResource AsterGraph.InspectorPanelPadding}"
          DataContext="{Binding Editor, ElementName=Root}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="{DynamicResource AsterGraph.DefaultSpacing}">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding InspectorChromeTitle}"
                     FontSize="{DynamicResource AsterGraph.SectionEyebrowFontSize}"
                     FontWeight="Bold"
                     Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
          <TextBlock Text="{Binding InspectorTitle}"
                     FontSize="{DynamicResource AsterGraph.InspectorTitleFontSize}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
          <TextBlock Text="{Binding InspectorCategory}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     FontWeight="Bold"
                     Foreground="{DynamicResource AsterGraph.HighlightBrush}" />
          <TextBlock Text="{Binding SelectionCaption}"
                     FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                     Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
          <TextBlock Text="{Binding InspectorDescription}"
                     FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource AsterGraph.BodyBrush}" />
        </StackPanel>

        <Border Classes="astergraph-inspector-section">
          <StackPanel Spacing="{DynamicResource AsterGraph.InspectorSectionSpacing}">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding InspectorConnectionsTitle}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding InspectorConnections}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding InspectorInputsTitle}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding InspectorInputs}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding InspectorOutputsTitle}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding InspectorOutputs}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="astergraph-inspector-section">
          <StackPanel Spacing="{DynamicResource AsterGraph.InspectorSectionSpacing}">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding InspectorUpstreamTitle}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding InspectorUpstream}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding InspectorDownstreamTitle}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
              <TextBlock Text="{Binding InspectorDownstream}"
                         FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="astergraph-inspector-section"
                IsVisible="{Binding HasAnyEditableParameters, Mode=OneWay}">
          <StackPanel Spacing="{DynamicResource AsterGraph.InspectorSectionSpacing}">
            <TextBlock Text="{Binding InspectorParametersTitle}"
                       FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
            <TextBlock Text="{Binding InspectorParametersIntro}"
                       FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                       Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            <TextBlock Text="{Binding InspectorParametersSurfaceHint}"
                       FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            <Border Classes="astergraph-parameter-guidance">
              <TextBlock Text="{Binding InspectorParametersGuidance}"
                         FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
            </Border>

            <TextBox x:Name="PART_ParameterSearchBox"
                     Classes="astergraph-input"
                     Watermark="{Binding InspectorParametersSearchWatermark}"
                     TextChanged="HandleParameterSearchTextChanged" />

            <Button x:Name="PART_AdvancedParametersToggleButton"
                    Classes="astergraph-group-toggle"
                    HorizontalAlignment="Left"
                    Content="显示高级参数"
                    Click="HandleAdvancedParametersToggleClick"
                    IsVisible="False" />

            <Border x:Name="PART_ParameterValidationSummary"
                    Classes="astergraph-parameter-state-pill"
                    Background="{DynamicResource AsterGraph.ValidationErrorBadgeBrush}"
                    IsVisible="False">
              <TextBlock x:Name="PART_ParameterValidationSummaryText"
                         FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.ValidationErrorBrush}" />
            </Border>

            <Border x:Name="PART_ParameterSearchEmptyState"
                    Classes="astergraph-parameter-guidance"
                    IsVisible="False">
              <TextBlock x:Name="PART_ParameterSearchEmptyStateText"
                         FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource AsterGraph.BodyBrush}" />
            </Border>

            <ItemsControl x:Name="PART_ParameterGroups">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="controls:GraphInspectorParameterGroupState">
                  <StackPanel Spacing="8">
                    <Border Classes="astergraph-parameter-group-header">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                            ColumnSpacing="8">
                        <Button Classes="astergraph-group-toggle"
                                Tag="{Binding GroupName}"
                                Click="HandleGroupToggleClick"
                                Content="{Binding ToggleCaption}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding GroupName}"
                                   FontSize="{DynamicResource AsterGraph.SectionEyebrowFontSize}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AsterGraph.HighlightBrush}"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Classes="astergraph-parameter-state-pill"
                                Background="{DynamicResource AsterGraph.ValidationErrorBadgeBrush}"
                                IsVisible="{Binding HasValidationIssues}">
                          <TextBlock Text="{Binding ValidationCaption}"
                                     FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                     Foreground="{DynamicResource AsterGraph.ValidationErrorBrush}" />
                        </Border>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding CountCaption}"
                                   FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                   Foreground="{DynamicResource AsterGraph.BodyBrush}"
                                   VerticalAlignment="Center" />
                      </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Parameters}"
                                  IsVisible="{Binding IsExpanded}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:NodeParameterViewModel">
                          <Border Classes="astergraph-parameter-card"
                                  Tag="{Binding Key}">
                            <StackPanel Spacing="8">
                              <Grid ColumnDefinitions="*,Auto"
                                    ColumnSpacing="8">
                                <StackPanel Spacing="2">
                                  <TextBlock Text="{Binding DisplayName}"
                                             FontSize="{DynamicResource AsterGraph.InspectorBodyFontSize}"
                                             FontWeight="SemiBold"
                                             Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                                  <TextBlock Text="{Binding Description}"
                                             FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                             TextWrapping="Wrap"
                                             Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Top">
                                  <Border Classes="astergraph-parameter-state-pill">
                                    <TextBlock Text="{Binding ValueStateCaption}"
                                               FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                               Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                                  </Border>
                                  <Border Classes="astergraph-parameter-state-pill"
                                          IsVisible="{Binding HasUnitSuffix}">
                                    <TextBlock Text="{Binding UnitSuffix}"
                                               FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                               Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                                  </Border>
                                  <Border Classes="astergraph-parameter-state-pill"
                                          IsVisible="{Binding IsAdvanced}">
                                    <TextBlock Text="高级"
                                               FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                               Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                                  </Border>
                                  <Border Classes="astergraph-parameter-state-pill"
                                          Background="{DynamicResource AsterGraph.ParameterEditableBadgeBrush}"
                                          IsVisible="{Binding CanEdit}">
                                    <TextBlock Text="可编辑"
                                               FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                               Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                                  </Border>
                                  <Border Classes="astergraph-parameter-state-pill"
                                          Background="{DynamicResource AsterGraph.ParameterReadOnlyBadgeBrush}"
                                          IsVisible="{Binding IsReadOnly}">
                                    <TextBlock Text="只读"
                                               FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                               Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                                  </Border>
                                  <Button Classes="astergraph-reset-parameter-button"
                                          Tag="{Binding Key}"
                                          Content="恢复默认"
                                          Click="HandleResetParameterClick"
                                          IsVisible="{Binding CanResetToDefault}"
                                          IsEnabled="{Binding CanResetToDefault}" />
                                </StackPanel>
                              </Grid>

                              <Border Classes="astergraph-parameter-guidance"
                                      IsVisible="{Binding HasHelpText}">
                                <TextBlock Text="{Binding HelpText}"
                                           FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource AsterGraph.BodyBrush}" />
                              </Border>

                              <TextBlock Text="编辑值"
                                         FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />

                              <controls:NodeParameterEditorHost Parameter="{Binding}"
                                                                 NodeParameterEditorRegistry="{Binding NodeParameterEditorRegistry, ElementName=Root}"
                                                                 TemplateKey="{Binding Definition.TemplateKey}"
                                                                 Usage="Inspector" />

                              <Border Classes="astergraph-parameter-state-pill"
                                      IsVisible="{Binding HasMixedValues}">
                                <TextBlock Text="包含多个节点的不同值，请确认后统一输入。"
                                           FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                           Foreground="{DynamicResource AsterGraph.EyebrowBrush}" />
                              </Border>

                              <Border Classes="astergraph-parameter-state-pill"
                                      Background="{DynamicResource AsterGraph.ParameterReadOnlyBadgeBrush}"
                                      IsVisible="{Binding HasReadOnlyReason}">
                                <TextBlock Text="{Binding ReadOnlyReason}"
                                           FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource AsterGraph.HeadlineBrush}" />
                              </Border>

                              <Border Classes="astergraph-parameter-state-pill"
                                      Background="{DynamicResource AsterGraph.ValidationErrorBadgeBrush}"
                                      IsVisible="{Binding HasValidationError}">
                                <TextBlock Text="{Binding ValidationMessage}"
                                           FontSize="{DynamicResource AsterGraph.InspectorCaptionFontSize}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource AsterGraph.ValidationErrorBrush}" />
                              </Border>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
