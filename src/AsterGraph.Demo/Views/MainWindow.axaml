<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsterGraph.Demo.ViewModels"
        xmlns:controls="using:AsterGraph.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1480"
        d:DesignHeight="900"
        x:Class="AsterGraph.Demo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AsterGraph Demo"
        Width="1480"
        Height="900"
        MinWidth="1280"
        MinHeight="760"
        Background="#09111A">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <DockPanel Margin="24"
             LastChildFill="True">
    <Border DockPanel.Dock="Top"
            Margin="0,0,0,16"
            Padding="14,12"
            Background="#101923"
            BorderBrush="#314859"
            BorderThickness="1"
            CornerRadius="10">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="16">
        <Menu x:Name="PART_HostMenu"
              Background="Transparent"
              Foreground="#F4FFFC">
          <MenuItem x:Name="PART_ShowcaseMenu"
                    Header="展示">
            <MenuItem Header="打开展示面板"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="展示" />
            <MenuItem Header="收起面板"
                      Command="{Binding CloseHostPaneCommand}" />
          </MenuItem>
          <MenuItem x:Name="PART_ViewMenu"
                    Header="视图">
            <MenuItem Header="打开视图面板"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="视图" />
          </MenuItem>
          <MenuItem x:Name="PART_BehaviorMenu"
                    Header="行为">
            <MenuItem Header="打开行为面板"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="行为" />
          </MenuItem>
          <MenuItem x:Name="PART_RuntimeMenu"
                    Header="运行时">
            <MenuItem Header="打开运行时面板"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="运行时" />
          </MenuItem>
          <MenuItem x:Name="PART_ProofMenu"
                    Header="证明">
            <MenuItem Header="打开证明面板"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="证明" />
          </MenuItem>
        </Menu>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Border Padding="10,6"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#7FE7D7"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Text="{Binding HostPaneStateCaption}" />
          </Border>
          <Border Padding="10,6"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#B6CBD8"
                       FontSize="12"
                       Text="{Binding HostSessionContinuityCaption}" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <SplitView x:Name="PART_HostShellSplitView"
               DisplayMode="Overlay"
               PanePlacement="Right"
               CompactPaneLength="0"
               OpenPaneLength="344"
               IsPaneOpen="{Binding IsHostPaneOpen}">
      <SplitView.Pane>
        <Border Padding="16"
                Background="#101923"
                BorderBrush="#314859"
                BorderThickness="1,0,0,0">
          <Grid RowDefinitions="Auto,*,Auto"
                RowSpacing="16">
            <StackPanel Spacing="6">
              <TextBlock FontSize="12"
                         FontWeight="Bold"
                         Foreground="#7FE7D7"
                         Text="宿主展示面板" />
              <TextBlock FontSize="22"
                         FontWeight="SemiBold"
                         Foreground="#F4FFFC"
                         Text="{Binding SelectedHostMenuGroupTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Foreground="#C2D7E4"
                         Text="{Binding SelectedHostMenuGroupSummary}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="12">
                <Border Padding="12"
                        Background="#14202B"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="8">
                  <TextBlock Foreground="#B6CBD8"
                             Text="{Binding HostPaneStateCaption}" />
                </Border>

                <Border Padding="12"
                        Background="#14202B"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="8">
                  <TextBlock x:Name="RuntimeDiagnosticsHelperText"
                             TextWrapping="Wrap"
                             Foreground="#7FE7D7"
                             Text="{Binding RuntimeDiagnosticsSummary}" />
                </Border>

                <ItemsControl ItemsSource="{Binding SelectedHostMenuGroupLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,8"
                              Padding="12"
                              Background="#14202B"
                              BorderBrush="#365063"
                              BorderThickness="1"
                              CornerRadius="8">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#D8EEF3"
                                   Text="{Binding}" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    Background="#14202B"
                    BorderBrush="#365063"
                    BorderThickness="1"
                    CornerRadius="8"
                    Command="{Binding CloseHostPaneCommand}"
                    Content="收起面板"
                    Foreground="#F4FFFC" />
          </Grid>
        </Border>
      </SplitView.Pane>

      <Border Background="#101923"
              BorderBrush="#314859"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="16">
          <Border x:Name="PART_GraphIntroStrip"
                  Padding="14"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock FontSize="12"
                           FontWeight="Bold"
                           Foreground="#7FE7D7"
                           Text="宿主级展示台" />
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#F4FFFC"
                           Text="实时节点图" />
                <TextBlock TextWrapping="Wrap"
                           Foreground="#C2D7E4"
                           Text="{Binding MainEditorSummary}" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          Spacing="8">
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock Foreground="#F4FFFC"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Text="宿主菜单" />
                </Border>
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock Foreground="#B6CBD8"
                             FontSize="12"
                             Text="单一实时会话" />
                </Border>
              </StackPanel>
            </Grid>
          </Border>

          <Border x:Name="MainEditorFrame"
                  Grid.Row="1"
                  Background="#08111A"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="8"
                  ClipToBounds="True">
            <controls:GraphEditorView x:Name="MainGraphEditorView"
                                      Editor="{Binding Editor}"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      IsHeaderChromeVisible="{Binding IsHeaderChromeVisible}"
                                      IsLibraryChromeVisible="{Binding IsLibraryChromeVisible}"
                                      IsInspectorChromeVisible="{Binding IsInspectorChromeVisible}"
                                      IsStatusChromeVisible="{Binding IsStatusChromeVisible}" />
          </Border>
        </Grid>
      </Border>
    </SplitView>
  </DockPanel>
</Window>
