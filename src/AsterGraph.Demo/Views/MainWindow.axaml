<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsterGraph.Demo.ViewModels"
        xmlns:controls="using:AsterGraph.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1520"
        d:DesignHeight="940"
        x:Class="AsterGraph.Demo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AsterGraph Demo"
        Width="1520"
        Height="940"
        MinWidth="1100"
        MinHeight="760"
        Background="#08111A">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <DockPanel>
    <Border DockPanel.Dock="Top"
            Margin="18,18,18,0"
            Padding="14,10"
            Background="#122130"
            BorderBrush="#2E4B5E"
            BorderThickness="1"
            CornerRadius="12">
      <WrapPanel Orientation="Horizontal"
                 VerticalAlignment="Center">
        <TextBlock Margin="0,0,18,0"
                   VerticalAlignment="Center"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#D9F7F1"
                   Text="Demo Drag Assist" />
        <CheckBox Margin="0,0,18,0"
                  VerticalAlignment="Center"
                  Foreground="#D9F7F1"
                  Content="Grid Snapping"
                  IsChecked="{Binding IsGridSnappingEnabled}" />
        <CheckBox VerticalAlignment="Center"
                  Foreground="#D9F7F1"
                  Content="Alignment Guides"
                  IsChecked="{Binding IsAlignmentGuidesEnabled}" />
      </WrapPanel>
    </Border>

    <controls:GraphEditorView Editor="{Binding Editor}" />
  </DockPanel>
</Window>
