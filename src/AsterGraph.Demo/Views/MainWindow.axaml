<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsterGraph.Demo.ViewModels"
        xmlns:controls="using:AsterGraph.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1480"
        d:DesignHeight="900"
        x:Class="AsterGraph.Demo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AsterGraph Demo"
        Width="1480"
        Height="900"
        MinWidth="1360"
        MinHeight="820"
        Background="#09111A">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid x:Name="MainShellGrid"
        Margin="24"
        ColumnSpacing="24"
        RowDefinitions="*"
        ColumnDefinitions="280,*,360">
    <ScrollViewer Grid.Column="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="16">
        <Border Padding="20"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="8">
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="AsterGraph SDK 展示台" />
            <TextBlock TextWrapping="Wrap"
                       Foreground="#C2D7E4"
                       Text="用一个保留的编辑器会话集中展示默认壳层、独立表面、可替换呈现与运行时诊断。" />
          </StackPanel>
        </Border>

        <Border Padding="16"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="12">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="能力导航" />
            <ItemsControl ItemsSource="{Binding Capabilities}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:MainWindowViewModel+CapabilityShowcaseItem">
                  <Button Margin="0,0,0,8"
                          Padding="14,12"
                          HorizontalContentAlignment="Stretch"
                          Background="#162433"
                          BorderBrush="#2C495D"
                          BorderThickness="1"
                          CornerRadius="12"
                          Command="{Binding $parent[Window].DataContext.SelectCapabilityCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Spacing="4">
                      <TextBlock FontWeight="SemiBold"
                                 Foreground="#F4FFFC"
                                 Text="{Binding Title}" />
                      <TextBlock TextWrapping="Wrap"
                                 Foreground="#B6CBD8"
                                 Text="{Binding Summary}" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Padding="16"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="12">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="宿主开关" />
            <CheckBox Foreground="#E2F3F7"
                      Content="网格吸附"
                      IsChecked="{Binding IsGridSnappingEnabled}" />
            <CheckBox Foreground="#E2F3F7"
                      Content="对齐辅助线"
                      IsChecked="{Binding IsAlignmentGuidesEnabled}" />
            <CheckBox Foreground="#E2F3F7"
                      Content="只读模式"
                      IsChecked="{Binding IsReadOnlyEnabled}" />
            <CheckBox Foreground="#E2F3F7"
                      Content="工作区命令"
                      IsChecked="{Binding AreWorkspaceCommandsEnabled}" />
            <CheckBox Foreground="#E2F3F7"
                      Content="片段命令"
                      IsChecked="{Binding AreFragmentCommandsEnabled}" />
            <CheckBox Foreground="#E2F3F7"
                      Content="宿主菜单扩展"
                      IsChecked="{Binding AreHostMenuExtensionsEnabled}" />
          </StackPanel>
        </Border>

        <Border Padding="16"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="10">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="演示入口" />
            <ItemsControl ItemsSource="{Binding DemoEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8"
                          Padding="12"
                          Background="#162433"
                          BorderBrush="#2C495D"
                          BorderThickness="1"
                          CornerRadius="12">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#B6CBD8"
                               Text="{Binding}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Column="1"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="16">
      <Border Padding="20"
              Background="#111C29"
              BorderBrush="#244053"
              BorderThickness="1"
              CornerRadius="16">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="16">
          <StackPanel Spacing="6">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="完整壳层演示" />
            <TextBlock TextWrapping="Wrap"
                       Foreground="#C2D7E4"
                       Text="{Binding SelectedCapabilitySummary}" />
          </StackPanel>
          <Border Grid.Column="1"
                  Padding="10,6"
                  Background="#162433"
                  BorderBrush="#2C495D"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#7FE7D7"
                       FontWeight="SemiBold"
                       Text="{Binding SelectedCapabilityTitle}" />
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Padding="16"
              Background="#111C29"
              BorderBrush="#244053"
              BorderThickness="1"
              CornerRadius="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="12">
            <StackPanel Spacing="4">
              <TextBlock FontSize="24"
                         FontWeight="SemiBold"
                         Foreground="#F4FFFC"
                         Text="主编辑器" />
              <TextBlock TextWrapping="Wrap"
                         Foreground="#C2D7E4"
                         Text="{Binding MainEditorSummary}" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="10,6"
                    Background="#162433"
                    BorderBrush="#2C495D"
                    BorderThickness="1"
                    CornerRadius="999"
                    VerticalAlignment="Top">
              <TextBlock Foreground="#B6CBD8"
                         Text="单一实时会话" />
            </Border>
          </Grid>
          <Border Height="500"
                  ClipToBounds="True"
                  Background="#08111A"
                  BorderBrush="#29475A"
                  BorderThickness="1"
                  CornerRadius="16">
            <controls:GraphEditorView Editor="{Binding Editor}" />
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Row="2"
              Padding="16"
              Background="#111C29"
              BorderBrush="#244053"
              BorderThickness="1"
              CornerRadius="16">
        <StackPanel Spacing="10">
          <TextBlock FontSize="24"
                     FontWeight="SemiBold"
                     Foreground="#F4FFFC"
                     Text="能力证明" />
          <ItemsControl ItemsSource="{Binding ChromeModeProofLines}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8"
                        Padding="12"
                        Background="#162433"
                        BorderBrush="#2C495D"
                        BorderThickness="1"
                        CornerRadius="12">
                  <TextBlock TextWrapping="Wrap"
                             Foreground="#C2D7E4"
                             Text="{Binding}" />
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </Grid>

    <ScrollViewer Grid.Column="2"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="16">
        <Border Padding="20"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="8">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="架构说明" />
            <TextBlock FontWeight="SemiBold"
                       Foreground="#7FE7D7"
                       Text="{Binding SelectedCapabilityTitle}" />
            <TextBlock TextWrapping="Wrap"
                       Foreground="#C2D7E4"
                       Text="{Binding SelectedCapabilityArchitecture}" />
            <ItemsControl ItemsSource="{Binding SelectedCapabilityBullets}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Margin="0,0,0,8"
                             TextWrapping="Wrap"
                             Foreground="#B6CBD8"
                             Text="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl ItemsSource="{Binding SelectedCapabilityProofLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8"
                          Padding="12"
                          Background="#162433"
                          BorderBrush="#2C495D"
                          BorderThickness="1"
                          CornerRadius="12">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#D8EEF3"
                               Text="{Binding}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Padding="16"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="12">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="运行时与诊断" />
            <TextBlock x:Name="RuntimeDiagnosticsHelperText"
                       TextWrapping="Wrap"
                       Foreground="#7FE7D7"
                       Text="{Binding RuntimeDiagnosticsSummary}" />

            <Border Padding="12"
                    Background="#162433"
                    BorderBrush="#2C495D"
                    BorderThickness="1"
                    CornerRadius="12">
              <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold"
                           Foreground="#F4FFFC"
                           Text="检查快照" />
                <TextBlock Foreground="#B6CBD8"
                           Text="{Binding RuntimeSessionInterfaceName, StringFormat=会话入口：{0}}" />
                <TextBlock Foreground="#B6CBD8"
                           Text="{Binding RuntimeDiagnosticsSourceName, StringFormat=诊断来源：{0}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeDocumentTitle, StringFormat=文档标题：{0}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeNodeCount, StringFormat=节点数量：{0}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeConnectionCount, StringFormat=连线数量：{0}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeSelectedNodeCount, StringFormat=当前选择：{0}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeViewportZoom, StringFormat=视口缩放：{0:0.00}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeViewportPanX, StringFormat=视口平移 X：{0:0}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeViewportPanY, StringFormat=视口平移 Y：{0:0}}" />
                <TextBlock Foreground="#C2D7E4"
                           Text="{Binding RuntimeHasPendingConnection, StringFormat=待完成连线：{0}}" />
              </StackPanel>
            </Border>

            <Border Padding="12"
                    Background="#162433"
                    BorderBrush="#2C495D"
                    BorderThickness="1"
                    CornerRadius="12">
              <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold"
                           Foreground="#F4FFFC"
                           Text="最近诊断" />
                <ItemsControl ItemsSource="{Binding RecentDiagnostics}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:MainWindowViewModel+RuntimeDiagnosticEntry">
                      <Border Margin="0,0,0,8"
                              Padding="12"
                              Background="#0E1824"
                              BorderBrush="#34536B"
                              BorderThickness="1"
                              CornerRadius="12">
                        <StackPanel Spacing="4">
                          <TextBlock Foreground="{Binding SeverityHex}"
                                     Text="{Binding SeverityLabel, StringFormat=Severity：{0}}" />
                          <TextBlock Foreground="#D8EEF3"
                                     Text="{Binding Code, StringFormat=Code：{0}}" />
                          <TextBlock Foreground="#D8EEF3"
                                     Text="{Binding Operation, StringFormat=Operation：{0}}" />
                          <TextBlock TextWrapping="Wrap"
                                     Foreground="#C2D7E4"
                                     Text="{Binding Message, StringFormat=Message：{0}}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Foreground="#B6CBD8"
                           Text="{Binding CompatibilityStatusMessage, StringFormat=兼容状态栏文案：{0}}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Padding="16"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="10">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="独立表面" />
            <ItemsControl ItemsSource="{Binding StandaloneSurfaceLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8"
                          Padding="12"
                          Background="#162433"
                          BorderBrush="#2C495D"
                          BorderThickness="1"
                          CornerRadius="12">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#C2D7E4"
                               Text="{Binding}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Padding="16"
                Background="#111C29"
                BorderBrush="#244053"
                BorderThickness="1"
                CornerRadius="16">
          <StackPanel Spacing="10">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F4FFFC"
                       Text="可替换呈现" />
            <ItemsControl ItemsSource="{Binding PresentationLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8"
                          Padding="12"
                          Background="#162433"
                          BorderBrush="#2C495D"
                          BorderThickness="1"
                          CornerRadius="12">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#C2D7E4"
                               Text="{Binding}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
