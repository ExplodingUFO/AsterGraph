<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsterGraph.Demo.ViewModels"
        xmlns:controls="using:AsterGraph.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1480"
        d:DesignHeight="900"
        x:Class="AsterGraph.Demo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AsterGraph Demo"
        Width="1480"
        Height="900"
        MinWidth="1280"
        MinHeight="760"
        Background="#09111A">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://AsterGraph.Demo/Views/Resources/MainWindowResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <DockPanel Margin="24"
             LastChildFill="True">
    <Border DockPanel.Dock="Top"
            Margin="0,0,0,16"
            Padding="14,12"
            Background="#101923"
            BorderBrush="#314859"
            BorderThickness="1"
            CornerRadius="10">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="16">
        <Menu x:Name="PART_HostMenu"
              Background="Transparent"
              Foreground="#F4FFFC">
          <MenuItem x:Name="PART_ShowcaseMenu"
                    Header="{Binding UiText[menu.showcase]}">
            <MenuItem Header="{Binding UiText[menu.showcase.open]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="showcase" />
            <MenuItem Header="{Binding UiText[menu.pane.close]}"
                      Command="{Binding CloseHostPaneCommand}" />
          </MenuItem>
          <MenuItem x:Name="PART_ViewMenu"
                    Header="{Binding UiText[menu.view]}">
            <MenuItem Header="{Binding UiText[menu.view.header]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsHeaderChromeVisible, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.view.library]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsLibraryChromeVisible, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.view.inspector]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsInspectorChromeVisible, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.view.status]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsStatusChromeVisible, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.view.minimap]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsMiniMapVisible, Mode=TwoWay}" />
            <Separator />
            <MenuItem Header="{Binding UiText[menu.view.open]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="view" />
          </MenuItem>
          <MenuItem x:Name="PART_BehaviorMenu"
                    Header="{Binding UiText[menu.behavior]}">
            <MenuItem Header="{Binding UiText[menu.behavior.readOnly]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsReadOnlyEnabled, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.behavior.grid]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsGridSnappingEnabled, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.behavior.guides]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsAlignmentGuidesEnabled, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.behavior.workspace]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding AreWorkspaceCommandsEnabled, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.behavior.fragments]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding AreFragmentCommandsEnabled, Mode=TwoWay}" />
            <MenuItem Header="{Binding UiText[menu.behavior.hostExtensions]}"
                      ToggleType="CheckBox"
                      IsChecked="{Binding AreHostMenuExtensionsEnabled, Mode=TwoWay}" />
            <Separator />
            <MenuItem Header="{Binding UiText[menu.behavior.open]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="behavior" />
          </MenuItem>
          <MenuItem x:Name="PART_RuntimeMenu"
                    Header="{Binding UiText[menu.runtime]}">
            <MenuItem Header="{Binding UiText[menu.runtime.state]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="runtime" />
            <MenuItem Header="{Binding UiText[menu.runtime.diagnostics]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="runtime" />
            <Separator />
            <MenuItem Header="{Binding UiText[menu.runtime.saveAs]}"
                      Command="{Binding SaveWorkspaceAsShellCommand}" />
            <MenuItem Header="{Binding UiText[menu.runtime.reopenLast]}"
                      Command="{Binding ReopenLastWorkspaceShellCommand}" />
            <MenuItem Header="{Binding UiText[menu.runtime.restoreDraft]}"
                      Command="{Binding RestoreAutosaveDraftShellCommand}"
                      IsEnabled="{Binding HasAutosaveDraft}" />
          </MenuItem>
          <MenuItem x:Name="PART_ExtensionsMenu"
                    Header="{Binding UiText[menu.extensions]}">
            <MenuItem Header="{Binding UiText[menu.extensions.candidates]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="extensions" />
            <MenuItem Header="{Binding UiText[menu.extensions.loading]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="extensions" />
          </MenuItem>
          <MenuItem x:Name="PART_AutomationMenu"
                    Header="{Binding UiText[menu.automation]}">
            <MenuItem Header="{Binding UiText[menu.automation.runSelection]}"
                      Command="{Binding RunSelectionAutomationCommand}" />
            <MenuItem Header="{Binding UiText[menu.automation.runPlugin]}"
                      Command="{Binding RunPluginAutomationCommand}" />
            <MenuItem Header="{Binding UiText[menu.automation.open]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="automation" />
          </MenuItem>
          <MenuItem x:Name="PART_IntegrationMenu"
                    Header="{Binding UiText[menu.integration]}">
            <MenuItem Header="{Binding UiText[menu.integration.consumerPath]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="integration" />
            <MenuItem Header="{Binding UiText[menu.integration.standalone]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="integration" />
          </MenuItem>
          <MenuItem x:Name="PART_LanguageMenu"
                    Header="{Binding UiText[menu.language]}">
            <MenuItem Header="中文"
                      Command="{Binding SelectLanguageCommand}"
                      CommandParameter="zh-CN" />
            <MenuItem Header="English"
                      Command="{Binding SelectLanguageCommand}"
                      CommandParameter="en" />
          </MenuItem>
          <MenuItem x:Name="PART_ProofMenu"
                    Header="{Binding UiText[menu.proof]}">
            <MenuItem Header="{Binding UiText[menu.proof.boundary]}"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="proof" />
          </MenuItem>
        </Menu>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Border Padding="10,6"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#F4FFFC"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Text="{Binding CurrentLanguageBadgeText}" />
          </Border>
          <Border Padding="10,6"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#7FE7D7"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Text="{Binding HostPaneStateCaption}" />
          </Border>
          <Border Padding="10,6"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#B6CBD8"
                       FontSize="12"
                       Text="{Binding HostSessionContinuityCaption}" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <SplitView x:Name="PART_HostShellSplitView"
               DisplayMode="Overlay"
               PanePlacement="Right"
               CompactPaneLength="0"
               OpenPaneLength="344"
               IsPaneOpen="{Binding IsHostPaneOpen, Mode=TwoWay}">
      <SplitView.Pane>
        <Border Padding="16"
                Background="#101923"
                BorderBrush="#314859"
                BorderThickness="1,0,0,0">
          <Grid RowDefinitions="Auto,*,Auto"
                RowSpacing="16">
            <StackPanel Spacing="6">
              <TextBlock x:Name="PART_HostDrawerCaptionText"
                         FontSize="12"
                         FontWeight="Bold"
                         Foreground="#7FE7D7"
                         Text="{Binding HostDrawerCaption}" />
              <TextBlock FontSize="22"
                         FontWeight="SemiBold"
                         Foreground="#F4FFFC"
                         Text="{Binding SelectedHostMenuGroupTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Foreground="#C2D7E4"
                         Text="{Binding SelectedHostMenuGroupSummary}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="12">
                <Border Padding="12"
                        Background="#14202B"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="8">
                  <TextBlock Foreground="#B6CBD8"
                             Text="{Binding HostPaneStateCaption}" />
                </Border>

                <StackPanel x:Name="PART_ShowcaseDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsShowcaseHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="10">
                      <TextBlock FontSize="12"
                                 FontWeight="Bold"
                                 Foreground="#7FE7D7"
                                 Text="{Binding UiText[showcase.heading]}" />
                      <ListBox ItemsSource="{Binding Capabilities}"
                               SelectedItem="{Binding SelectedCapability, Mode=TwoWay}"
                               Background="Transparent"
                               BorderThickness="0">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="#F4FFFC" />
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </StackPanel>
                  </Border>
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <TextBlock FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#F4FFFC"
                                 Text="{Binding SelectedCapabilityTitle}" />
                      <TextBlock TextWrapping="Wrap"
                                 Foreground="#C2D7E4"
                                 Text="{Binding SelectedCapabilitySummary}" />
                      <ItemsControl ItemsSource="{Binding SelectedCapabilityBullets}"
                                    ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                    </StackPanel>
                  </Border>
                  <ItemsControl ItemsSource="{Binding SelectedHostMenuGroupLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_ViewDrawerControls"
                            Spacing="8"
                            IsVisible="{Binding IsViewHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#7FE7D7"
                               Text="{Binding SelectedHostMenuGroupSummary}" />
                  </Border>

                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <CheckBox Content="{Binding UiText[menu.view.header]}"
                                IsChecked="{Binding IsHeaderChromeVisible}" />
                      <CheckBox Content="{Binding UiText[menu.view.library]}"
                                IsChecked="{Binding IsLibraryChromeVisible}" />
                      <CheckBox Content="{Binding UiText[menu.view.inspector]}"
                                IsChecked="{Binding IsInspectorChromeVisible}" />
                      <CheckBox Content="{Binding UiText[menu.view.status]}"
                                IsChecked="{Binding IsStatusChromeVisible}" />
                      <CheckBox Content="{Binding UiText[menu.view.minimap]}"
                                IsChecked="{Binding IsMiniMapVisible}" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel x:Name="PART_BehaviorDrawerControls"
                            Spacing="8"
                            IsVisible="{Binding IsBehaviorHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#7FE7D7"
                               Text="{Binding SelectedHostMenuGroupSummary}" />
                  </Border>

                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <CheckBox Content="{Binding UiText[menu.behavior.readOnly]}"
                                IsChecked="{Binding IsReadOnlyEnabled}" />
                      <CheckBox Content="{Binding UiText[menu.behavior.grid]}"
                                IsChecked="{Binding IsGridSnappingEnabled}" />
                      <CheckBox Content="{Binding UiText[menu.behavior.guides]}"
                                IsChecked="{Binding IsAlignmentGuidesEnabled}" />
                      <CheckBox Content="{Binding UiText[menu.behavior.workspace]}"
                                IsChecked="{Binding AreWorkspaceCommandsEnabled}" />
                      <CheckBox Content="{Binding UiText[menu.behavior.fragments]}"
                                IsChecked="{Binding AreFragmentCommandsEnabled}" />
                      <CheckBox Content="{Binding UiText[menu.behavior.hostExtensions]}"
                                IsChecked="{Binding AreHostMenuExtensionsEnabled}" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel x:Name="PART_RuntimeSummarySection"
                            Spacing="8"
                            IsVisible="{Binding IsRuntimeHostGroupSelected}">
                  <StackPanel x:Name="PART_RuntimeConfigurationSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_RuntimeConfigurationHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="{Binding UiText[runtime.config.heading]}" />
                    <ItemsControl ItemsSource="{Binding CurrentConfigurationLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_RuntimeSignalsSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_RuntimeSignalsHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="{Binding UiText[runtime.signals.heading]}" />
                    <ItemsControl ItemsSource="{Binding RuntimeSignalLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_RuntimeShellSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_RuntimeShellHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="{Binding UiText[runtime.shell.heading]}" />
                    <Border Padding="12"
                            Background="#14202B"
                            BorderBrush="#365063"
                            BorderThickness="1"
                            CornerRadius="8">
                      <StackPanel Spacing="8">
                        <Button x:Name="PART_RuntimeSaveAsButton"
                                Padding="10,8"
                                Background="#101923"
                                BorderBrush="#365063"
                                BorderThickness="1"
                                CornerRadius="8"
                                Command="{Binding SaveWorkspaceAsShellCommand}"
                                Content="{Binding UiText[menu.runtime.saveAs]}"
                                Foreground="#F4FFFC" />
                        <Button x:Name="PART_RuntimeReopenLastButton"
                                Padding="10,8"
                                Background="#101923"
                                BorderBrush="#365063"
                                BorderThickness="1"
                                CornerRadius="8"
                                Command="{Binding ReopenLastWorkspaceShellCommand}"
                                Content="{Binding UiText[menu.runtime.reopenLast]}"
                                Foreground="#F4FFFC" />
                        <Button x:Name="PART_RuntimeRestoreDraftButton"
                                Padding="10,8"
                                Background="#101923"
                                BorderBrush="#365063"
                                BorderThickness="1"
                                CornerRadius="8"
                                Command="{Binding RestoreAutosaveDraftShellCommand}"
                                Content="{Binding UiText[menu.runtime.restoreDraft]}"
                                Foreground="#F4FFFC"
                                IsEnabled="{Binding HasAutosaveDraft}" />
                        <TextBlock x:Name="PART_DirtyExitPromptText"
                                   TextWrapping="Wrap"
                                   Foreground="#F3C97A"
                                   IsVisible="{Binding DirtyExitPromptPending}"
                                   Text="{Binding DirtyExitPromptMessage}" />
                      </StackPanel>
                    </Border>
                    <ItemsControl x:Name="PART_RuntimeShellLines"
                                  ItemsSource="{Binding ShellWorkflowLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                    <ItemsControl x:Name="PART_RuntimeRecentWorkspaceItems"
                                  ItemsSource="{Binding RecentWorkspaceEntries}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecentWorkspaceEntry">
                          <Button Padding="10,8"
                                  HorizontalAlignment="Stretch"
                                  Background="#101923"
                                  BorderBrush="#365063"
                                  BorderThickness="1"
                                  CornerRadius="8"
                                  Command="{Binding $parent[Window].DataContext.OpenRecentWorkspaceCommand}"
                                  CommandParameter="{Binding Path}"
                                  Content="{Binding DisplayName}"
                                  Foreground="#F4FFFC" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>

                <StackPanel x:Name="PART_RuntimeInspectionSection"
                            Spacing="8"
                            IsVisible="{Binding IsRuntimeHostGroupSelected}">
                  <TextBlock x:Name="PART_RuntimeInspectionHeading"
                             FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding RuntimeInspectionSurface.Heading}" />

                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="12">
                      <StackPanel x:Name="PART_RuntimeInspectionDocumentSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionDocumentHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.Document.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionDocumentLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.Document.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionSelectionSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionSelectionHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.Selection.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionSelectionLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.Selection.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionViewportSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionViewportHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.Viewport.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionViewportLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.Viewport.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionCapabilitySection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionCapabilityHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.Capabilities.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionCapabilityLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.Capabilities.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionPendingConnectionSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionPendingConnectionHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.PendingConnection.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionPendingConnectionLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.PendingConnection.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionFeatureSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionFeatureHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.FeatureDescriptors.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionFeatureLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.FeatureDescriptors.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionCommandTimelineSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionCommandTimelineHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.CommandTimeline.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionCommandTimelineLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.CommandTimeline.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionDiagnosticsSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionDiagnosticsHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.RecentDiagnostics.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionDiagnosticsLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.RecentDiagnostics.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>

                      <StackPanel x:Name="PART_RuntimeInspectionPluginSection"
                                  Spacing="8">
                        <TextBlock x:Name="PART_RuntimeInspectionPluginHeading"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#7FE7D7"
                                   Text="{Binding RuntimeInspectionSurface.PluginLoads.Heading}" />
                        <ItemsControl x:Name="PART_RuntimeInspectionPluginLines"
                                      ItemsSource="{Binding RuntimeInspectionSurface.PluginLoads.Lines}"
                                      ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel x:Name="PART_RuntimeDiagnosticsSection"
                            Spacing="8"
                            IsVisible="{Binding IsRuntimeHostGroupSelected}">
                  <TextBlock x:Name="PART_RuntimeDiagnosticsHeading"
                             FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[runtime.diagnostics.heading]}" />
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <TextBlock x:Name="RuntimeDiagnosticsHelperText"
                               TextWrapping="Wrap"
                               Foreground="#7FE7D7"
                               Text="{Binding RuntimeDiagnosticsSummary}" />
                  </Border>

                  <ItemsControl ItemsSource="{Binding RecentDiagnosticLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_ExtensionDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsExtensionsHostGroupSelected}">
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[extensions.candidates.heading]}" />
                  <ItemsControl x:Name="PART_PluginCandidateEntries"
                                ItemsSource="{Binding PluginCandidateEntries}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:PluginCandidateEntry">
                        <Border Margin="0,0,0,8"
                                Padding="12"
                                Background="#14202B"
                                BorderBrush="#365063"
                                BorderThickness="1"
                                CornerRadius="8">
                          <StackPanel Spacing="6">
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#F4FFFC"
                                       Text="{Binding DisplayName}" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#D8EEF3"
                                       Text="{Binding SummaryLine}" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#B6CBD8"
                                       Text="{Binding ProvenanceLine}" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#7FE7D7"
                                       Text="{Binding TrustLine}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                              <Button Padding="10,6"
                                      Background="#101923"
                                      BorderBrush="#365063"
                                      BorderThickness="1"
                                      CornerRadius="8"
                                      Command="{Binding $parent[Window].DataContext.TrustPluginCandidateShellCommand}"
                                      CommandParameter="{Binding PluginId}"
                                      Content="Trust"
                                      Foreground="#F4FFFC"
                                      IsEnabled="{Binding IsBlocked}" />
                              <Button Padding="10,6"
                                      Background="#101923"
                                      BorderBrush="#365063"
                                      BorderThickness="1"
                                      CornerRadius="8"
                                      Command="{Binding $parent[Window].DataContext.BlockPluginCandidateShellCommand}"
                                      CommandParameter="{Binding PluginId}"
                                      Content="Block"
                                      Foreground="#F4FFFC"
                                      IsEnabled="{Binding IsAllowed}" />
                            </StackPanel>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <ItemsControl ItemsSource="{Binding PluginCandidateLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[extensions.allowlist.heading]}" />
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8">
                        <Button x:Name="PART_ExportPluginAllowlistButton"
                                Padding="10,8"
                                Background="#101923"
                                BorderBrush="#365063"
                                BorderThickness="1"
                                CornerRadius="8"
                                Command="{Binding ExportPluginAllowlistShellCommand}"
                                Content="{Binding UiText[menu.extensions.exportAllowlist]}"
                                Foreground="#F4FFFC" />
                        <Button x:Name="PART_ImportPluginAllowlistButton"
                                Padding="10,8"
                                Background="#101923"
                                BorderBrush="#365063"
                                BorderThickness="1"
                                CornerRadius="8"
                                Command="{Binding ImportPluginAllowlistShellCommand}"
                                Content="{Binding UiText[menu.extensions.importAllowlist]}"
                                Foreground="#F4FFFC" />
                      </StackPanel>
                      <ItemsControl x:Name="PART_PluginAllowlistItems"
                                    ItemsSource="{Binding PluginAllowlistLines}"
                                    ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                    </StackPanel>
                  </Border>
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[extensions.loads.heading]}" />
                  <ItemsControl ItemsSource="{Binding PluginLoadLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_AutomationDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsAutomationHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <Button x:Name="PART_RunSelectionAutomationButton"
                              Padding="10,8"
                              Background="#101923"
                              BorderBrush="#365063"
                              BorderThickness="1"
                              CornerRadius="8"
                              Command="{Binding RunSelectionAutomationCommand}"
                              Content="{Binding UiText[menu.automation.runSelection]}"
                              Foreground="#F4FFFC" />
                      <Button x:Name="PART_RunPluginAutomationButton"
                              Padding="10,8"
                              Background="#101923"
                              BorderBrush="#365063"
                              BorderThickness="1"
                              CornerRadius="8"
                              Command="{Binding RunPluginAutomationCommand}"
                              Content="{Binding UiText[menu.automation.runPlugin]}"
                              Foreground="#F4FFFC" />
                      <Button x:Name="PART_RunWorkspaceAutomationButton"
                              Padding="10,8"
                              Background="#101923"
                              BorderBrush="#365063"
                              BorderThickness="1"
                              CornerRadius="8"
                              Command="{Binding RunWorkspaceAutomationCommand}"
                              Content="{Binding UiText[menu.automation.runWorkspace]}"
                              Foreground="#F4FFFC" />
                    </StackPanel>
                  </Border>
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[automation.request.heading]}" />
                  <ItemsControl ItemsSource="{Binding AutomationRequestLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[automation.progress.heading]}" />
                  <ItemsControl ItemsSource="{Binding AutomationProgressLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[automation.result.heading]}" />
                  <ItemsControl ItemsSource="{Binding AutomationResultLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_IntegrationDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsIntegrationHostGroupSelected}">
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[integration.consumer.heading]}" />
                  <ItemsControl ItemsSource="{Binding ConsumerPathLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[integration.standalone.heading]}" />
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_StandaloneCanvasHost"
                                    MinHeight="180" />
                  </Border>
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_StandaloneInspectorHost" />
                  </Border>
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_StandaloneMiniMapHost"
                                    MinHeight="120" />
                  </Border>
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[integration.presentation.heading]}" />
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_CustomInspectorHost" />
                  </Border>
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_CustomMiniMapHost"
                                    MinHeight="120" />
                  </Border>
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="{Binding UiText[integration.localization.heading]}" />
                  <ItemsControl ItemsSource="{Binding LocalizationProofLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_ProofDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsProofHostGroupSelected}">
                  <StackPanel x:Name="PART_ProofConfigurationSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_ProofConfigurationHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="{Binding UiText[proof.config.heading]}" />
                    <ItemsControl ItemsSource="{Binding CurrentConfigurationLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_ProofOwnershipSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_ProofOwnershipHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="{Binding UiText[proof.ownership.heading]}" />
                    <ItemsControl ItemsSource="{Binding OwnershipProofLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_ProofRuntimeSignalsSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_ProofRuntimeSignalsHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="{Binding UiText[proof.runtime.heading]}" />
                    <ItemsControl ItemsSource="{Binding RuntimeSignalLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_ProofShellSignalsSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_ProofShellSignalsHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="{Binding UiText[proof.shell.heading]}" />
                    <ItemsControl ItemsSource="{Binding ShellWorkflowLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    Background="#14202B"
                    BorderBrush="#365063"
                    BorderThickness="1"
                    CornerRadius="8"
                    Command="{Binding CloseHostPaneCommand}"
                    Content="{Binding UiText[menu.pane.close]}"
                    Foreground="#F4FFFC" />
          </Grid>
        </Border>
      </SplitView.Pane>

      <Border Background="#101923"
              BorderBrush="#314859"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="16">
          <Border x:Name="PART_GraphIntroStrip"
                  Padding="14"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock FontSize="12"
                           FontWeight="Bold"
                           Foreground="#7FE7D7"
                           Text="{Binding UiText[intro.kicker]}" />
                <TextBlock x:Name="PART_GraphIntroTitleText"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#F4FFFC"
                           Text="{Binding LiveSessionTitle}" />
                <TextBlock TextWrapping="Wrap"
                           Foreground="#C2D7E4"
                           Text="{Binding MainEditorSummary}" />
                <WrapPanel x:Name="PART_CommandRail"
                           Margin="0,8,0,0"
                           Orientation="Horizontal"
                           ItemHeight="40"
                           ItemWidth="124" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          Spacing="8">
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="PART_HostOwnershipBadgeText"
                             Foreground="#F4FFFC"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Text="{Binding HostOwnershipBadgeText}" />
                </Border>
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="PART_RuntimeOwnershipBadgeText"
                             Foreground="#B6CBD8"
                             FontSize="12"
                             Text="{Binding RuntimeOwnershipBadgeText}" />
                </Border>
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="PART_ActiveHostGroupBadgeText"
                             Foreground="#7FE7D7"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Text="{Binding ActiveHostGroupBadgeText}" />
                </Border>
              </StackPanel>
            </Grid>
          </Border>

          <Border x:Name="MainEditorFrame"
                  Grid.Row="1"
                  Background="#08111A"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="8"
                  ClipToBounds="True">
            <ContentControl x:Name="PART_MainGraphEditorHost"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch" />
          </Border>
        </Grid>
      </Border>
    </SplitView>
  </DockPanel>
</Window>
