<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsterGraph.Demo.ViewModels"
        xmlns:controls="using:AsterGraph.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1480"
        d:DesignHeight="900"
        x:Class="AsterGraph.Demo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AsterGraph Demo"
        Width="1480"
        Height="900"
        MinWidth="1280"
        MinHeight="760"
        Background="#09111A">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://AsterGraph.Demo/Views/Resources/MainWindowResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <DockPanel Margin="24"
             LastChildFill="True">
    <Border DockPanel.Dock="Top"
            Margin="0,0,0,16"
            Padding="14,12"
            Background="#101923"
            BorderBrush="#314859"
            BorderThickness="1"
            CornerRadius="10">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="16">
        <Menu x:Name="PART_HostMenu"
              Background="Transparent"
              Foreground="#F4FFFC">
          <MenuItem x:Name="PART_ShowcaseMenu"
                    Header="展示">
            <MenuItem Header="打开展示摘要"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="展示" />
            <MenuItem Header="收起面板"
                      Command="{Binding CloseHostPaneCommand}" />
          </MenuItem>
          <MenuItem x:Name="PART_ViewMenu"
                    Header="视图">
            <MenuItem Header="显示顶栏"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsHeaderChromeVisible, Mode=TwoWay}" />
            <MenuItem Header="显示节点库"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsLibraryChromeVisible, Mode=TwoWay}" />
            <MenuItem Header="显示检查器"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsInspectorChromeVisible, Mode=TwoWay}" />
            <MenuItem Header="显示状态栏"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsStatusChromeVisible, Mode=TwoWay}" />
            <Separator />
            <MenuItem Header="打开视图控制"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="视图" />
          </MenuItem>
          <MenuItem x:Name="PART_BehaviorMenu"
                    Header="行为">
            <MenuItem Header="只读模式"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsReadOnlyEnabled, Mode=TwoWay}" />
            <MenuItem Header="网格吸附"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsGridSnappingEnabled, Mode=TwoWay}" />
            <MenuItem Header="对齐辅助线"
                      ToggleType="CheckBox"
                      IsChecked="{Binding IsAlignmentGuidesEnabled, Mode=TwoWay}" />
            <MenuItem Header="工作区命令"
                      ToggleType="CheckBox"
                      IsChecked="{Binding AreWorkspaceCommandsEnabled, Mode=TwoWay}" />
            <MenuItem Header="片段命令"
                      ToggleType="CheckBox"
                      IsChecked="{Binding AreFragmentCommandsEnabled, Mode=TwoWay}" />
            <MenuItem Header="宿主菜单扩展"
                      ToggleType="CheckBox"
                      IsChecked="{Binding AreHostMenuExtensionsEnabled, Mode=TwoWay}" />
            <Separator />
            <MenuItem Header="打开行为控制"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="行为" />
          </MenuItem>
          <MenuItem x:Name="PART_RuntimeMenu"
                    Header="运行时">
            <MenuItem Header="查看运行时状态"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="运行时" />
            <MenuItem Header="查看运行时诊断"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="运行时" />
          </MenuItem>
          <MenuItem x:Name="PART_ExtensionsMenu"
                    Header="扩展">
            <MenuItem Header="查看插件候选项"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="扩展" />
            <MenuItem Header="查看加载与信任"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="扩展" />
          </MenuItem>
          <MenuItem x:Name="PART_AutomationMenu"
                    Header="自动化">
            <MenuItem Header="运行焦点自动化"
                      Command="{Binding RunSelectionAutomationCommand}" />
            <MenuItem Header="运行插件自动化"
                      Command="{Binding RunPluginAutomationCommand}" />
            <MenuItem Header="打开自动化面板"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="自动化" />
          </MenuItem>
          <MenuItem x:Name="PART_IntegrationMenu"
                    Header="集成">
            <MenuItem Header="查看 consumer path"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="集成" />
            <MenuItem Header="查看独立表面"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="集成" />
          </MenuItem>
          <MenuItem x:Name="PART_ProofMenu"
                    Header="证明">
            <MenuItem Header="查看宿主边界"
                      Command="{Binding OpenHostMenuGroupCommand}"
                      CommandParameter="证明" />
          </MenuItem>
        </Menu>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
          <Border Padding="10,6"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#7FE7D7"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Text="{Binding HostPaneStateCaption}" />
          </Border>
          <Border Padding="10,6"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="999">
            <TextBlock Foreground="#B6CBD8"
                       FontSize="12"
                       Text="{Binding HostSessionContinuityCaption}" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <SplitView x:Name="PART_HostShellSplitView"
               DisplayMode="Overlay"
               PanePlacement="Right"
               CompactPaneLength="0"
               OpenPaneLength="344"
               IsPaneOpen="{Binding IsHostPaneOpen, Mode=TwoWay}">
      <SplitView.Pane>
        <Border Padding="16"
                Background="#101923"
                BorderBrush="#314859"
                BorderThickness="1,0,0,0">
          <Grid RowDefinitions="Auto,*,Auto"
                RowSpacing="16">
            <StackPanel Spacing="6">
              <TextBlock x:Name="PART_HostDrawerCaptionText"
                         FontSize="12"
                         FontWeight="Bold"
                         Foreground="#7FE7D7"
                         Text="{Binding HostDrawerCaption}" />
              <TextBlock FontSize="22"
                         FontWeight="SemiBold"
                         Foreground="#F4FFFC"
                         Text="{Binding SelectedHostMenuGroupTitle}" />
              <TextBlock TextWrapping="Wrap"
                         Foreground="#C2D7E4"
                         Text="{Binding SelectedHostMenuGroupSummary}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="12">
                <Border Padding="12"
                        Background="#14202B"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="8">
                  <TextBlock Foreground="#B6CBD8"
                             Text="{Binding HostPaneStateCaption}" />
                </Border>

                <StackPanel x:Name="PART_ShowcaseDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsShowcaseHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="10">
                      <TextBlock FontSize="12"
                                 FontWeight="Bold"
                                 Foreground="#7FE7D7"
                                 Text="Capability Showcase" />
                      <ListBox ItemsSource="{Binding Capabilities}"
                               SelectedItem="{Binding SelectedCapability, Mode=TwoWay}"
                               Background="Transparent"
                               BorderThickness="0">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="#F4FFFC" />
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </StackPanel>
                  </Border>
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <TextBlock FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="#F4FFFC"
                                 Text="{Binding SelectedCapabilityTitle}" />
                      <TextBlock TextWrapping="Wrap"
                                 Foreground="#C2D7E4"
                                 Text="{Binding SelectedCapabilitySummary}" />
                      <ItemsControl ItemsSource="{Binding SelectedCapabilityBullets}"
                                    ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                    </StackPanel>
                  </Border>
                  <ItemsControl ItemsSource="{Binding SelectedHostMenuGroupLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_ViewDrawerControls"
                            Spacing="8"
                            IsVisible="{Binding IsViewHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#7FE7D7"
                               Text="{Binding SelectedHostMenuGroupSummary}" />
                  </Border>

                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <CheckBox Content="显示顶栏"
                                IsChecked="{Binding IsHeaderChromeVisible}" />
                      <CheckBox Content="显示节点库"
                                IsChecked="{Binding IsLibraryChromeVisible}" />
                      <CheckBox Content="显示检查器"
                                IsChecked="{Binding IsInspectorChromeVisible}" />
                      <CheckBox Content="显示状态栏"
                                IsChecked="{Binding IsStatusChromeVisible}" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel x:Name="PART_BehaviorDrawerControls"
                            Spacing="8"
                            IsVisible="{Binding IsBehaviorHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#7FE7D7"
                               Text="{Binding SelectedHostMenuGroupSummary}" />
                  </Border>

                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <CheckBox Content="只读模式"
                                IsChecked="{Binding IsReadOnlyEnabled}" />
                      <CheckBox Content="网格吸附"
                                IsChecked="{Binding IsGridSnappingEnabled}" />
                      <CheckBox Content="对齐辅助线"
                                IsChecked="{Binding IsAlignmentGuidesEnabled}" />
                      <CheckBox Content="工作区命令"
                                IsChecked="{Binding AreWorkspaceCommandsEnabled}" />
                      <CheckBox Content="片段命令"
                                IsChecked="{Binding AreFragmentCommandsEnabled}" />
                      <CheckBox Content="宿主菜单扩展"
                                IsChecked="{Binding AreHostMenuExtensionsEnabled}" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel x:Name="PART_RuntimeSummarySection"
                            Spacing="8"
                            IsVisible="{Binding IsRuntimeHostGroupSelected}">
                  <StackPanel x:Name="PART_RuntimeConfigurationSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_RuntimeConfigurationHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="宿主开关快照" />
                    <ItemsControl ItemsSource="{Binding CurrentConfigurationLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_RuntimeSignalsSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_RuntimeSignalsHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="共享运行时状态" />
                    <ItemsControl ItemsSource="{Binding RuntimeSignalLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>
                </StackPanel>

                <StackPanel x:Name="PART_RuntimeDiagnosticsSection"
                            Spacing="8"
                            IsVisible="{Binding IsRuntimeHostGroupSelected}">
                  <TextBlock x:Name="PART_RuntimeDiagnosticsHeading"
                             FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="最近诊断" />
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <TextBlock x:Name="RuntimeDiagnosticsHelperText"
                               TextWrapping="Wrap"
                               Foreground="#7FE7D7"
                               Text="{Binding RuntimeDiagnosticsSummary}" />
                  </Border>

                  <ItemsControl ItemsSource="{Binding RecentDiagnosticLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_ExtensionDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsExtensionsHostGroupSelected}">
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Plugin Candidates" />
                  <ItemsControl ItemsSource="{Binding PluginCandidateLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Plugin Load Snapshots" />
                  <ItemsControl ItemsSource="{Binding PluginLoadLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_AutomationDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsAutomationHostGroupSelected}">
                  <Border Padding="12"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel Spacing="8">
                      <Button x:Name="PART_RunSelectionAutomationButton"
                              Padding="10,8"
                              Background="#101923"
                              BorderBrush="#365063"
                              BorderThickness="1"
                              CornerRadius="8"
                              Command="{Binding RunSelectionAutomationCommand}"
                              Content="运行焦点自动化"
                              Foreground="#F4FFFC" />
                      <Button x:Name="PART_RunPluginAutomationButton"
                              Padding="10,8"
                              Background="#101923"
                              BorderBrush="#365063"
                              BorderThickness="1"
                              CornerRadius="8"
                              Command="{Binding RunPluginAutomationCommand}"
                              Content="运行插件自动化"
                              Foreground="#F4FFFC" />
                      <Button x:Name="PART_RunWorkspaceAutomationButton"
                              Padding="10,8"
                              Background="#101923"
                              BorderBrush="#365063"
                              BorderThickness="1"
                              CornerRadius="8"
                              Command="{Binding RunWorkspaceAutomationCommand}"
                              Content="运行工作区自动化"
                              Foreground="#F4FFFC" />
                    </StackPanel>
                  </Border>
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Automation Request" />
                  <ItemsControl ItemsSource="{Binding AutomationRequestLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Automation Progress" />
                  <ItemsControl ItemsSource="{Binding AutomationProgressLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Automation Result" />
                  <ItemsControl ItemsSource="{Binding AutomationResultLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                </StackPanel>

                <StackPanel x:Name="PART_IntegrationDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsIntegrationHostGroupSelected}">
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Consumer Path" />
                  <ItemsControl ItemsSource="{Binding ConsumerPathLines}"
                                ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Standalone Surfaces" />
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_StandaloneCanvasHost"
                                    MinHeight="180" />
                  </Border>
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_StandaloneInspectorHost" />
                  </Border>
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_StandaloneMiniMapHost"
                                    MinHeight="120" />
                  </Border>
                  <TextBlock FontSize="12"
                             FontWeight="Bold"
                             Foreground="#7FE7D7"
                             Text="Presenter Replacement" />
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_CustomInspectorHost" />
                  </Border>
                  <Border Padding="8"
                          Background="#14202B"
                          BorderBrush="#365063"
                          BorderThickness="1"
                          CornerRadius="8">
                    <ContentControl x:Name="PART_CustomMiniMapHost"
                                    MinHeight="120" />
                  </Border>
                </StackPanel>

                <StackPanel x:Name="PART_ProofDrawerSection"
                            Spacing="8"
                            IsVisible="{Binding IsProofHostGroupSelected}">
                  <StackPanel x:Name="PART_ProofConfigurationSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_ProofConfigurationHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="宿主控制快照" />
                    <ItemsControl ItemsSource="{Binding CurrentConfigurationLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_ProofOwnershipSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_ProofOwnershipHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="边界证据" />
                    <ItemsControl ItemsSource="{Binding OwnershipProofLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>

                  <StackPanel x:Name="PART_ProofRuntimeSignalsSection"
                              Spacing="8">
                    <TextBlock x:Name="PART_ProofRuntimeSignalsHeading"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#7FE7D7"
                               Text="共享运行时证据" />
                    <ItemsControl ItemsSource="{Binding RuntimeSignalLines}"
                                  ItemTemplate="{StaticResource HostDrawerLineTemplate}" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Padding="12,10"
                    HorizontalAlignment="Stretch"
                    Background="#14202B"
                    BorderBrush="#365063"
                    BorderThickness="1"
                    CornerRadius="8"
                    Command="{Binding CloseHostPaneCommand}"
                    Content="收起面板"
                    Foreground="#F4FFFC" />
          </Grid>
        </Border>
      </SplitView.Pane>

      <Border Background="#101923"
              BorderBrush="#314859"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="16">
          <Border x:Name="PART_GraphIntroStrip"
                  Padding="14"
                  Background="#14202B"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock FontSize="12"
                           FontWeight="Bold"
                           Foreground="#7FE7D7"
                           Text="宿主级展示台" />
                <TextBlock x:Name="PART_GraphIntroTitleText"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#F4FFFC"
                           Text="{Binding LiveSessionTitle}" />
                <TextBlock TextWrapping="Wrap"
                           Foreground="#C2D7E4"
                           Text="{Binding MainEditorSummary}" />
              </StackPanel>

              <StackPanel Grid.Column="1"
                          HorizontalAlignment="Right"
                          Spacing="8">
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="PART_HostOwnershipBadgeText"
                             Foreground="#F4FFFC"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Text="{Binding HostOwnershipBadgeText}" />
                </Border>
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="PART_RuntimeOwnershipBadgeText"
                             Foreground="#B6CBD8"
                             FontSize="12"
                             Text="{Binding RuntimeOwnershipBadgeText}" />
                </Border>
                <Border Padding="10,6"
                        Background="#101923"
                        BorderBrush="#365063"
                        BorderThickness="1"
                        CornerRadius="999">
                  <TextBlock x:Name="PART_ActiveHostGroupBadgeText"
                             Foreground="#7FE7D7"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Text="{Binding ActiveHostGroupBadgeText}" />
                </Border>
              </StackPanel>
            </Grid>
          </Border>

          <Border x:Name="MainEditorFrame"
                  Grid.Row="1"
                  Background="#08111A"
                  BorderBrush="#365063"
                  BorderThickness="1"
                  CornerRadius="8"
                  ClipToBounds="True">
            <ContentControl x:Name="PART_MainGraphEditorHost"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch" />
          </Border>
        </Grid>
      </Border>
    </SplitView>
  </DockPanel>
</Window>
