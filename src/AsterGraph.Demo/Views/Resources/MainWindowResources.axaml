<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DataTemplate x:Key="HostDrawerLineTemplate">
    <Border Margin="0,0,0,8"
            Padding="12"
            Background="#14202B"
            BorderBrush="#365063"
            BorderThickness="1"
            CornerRadius="8">
      <TextBlock TextWrapping="Wrap"
                 Foreground="#D8EEF3"
                 Text="{Binding}" />
    </Border>
  </DataTemplate>

  <DataTemplate x:Key="CookbookNavigationFeedbackLineTemplate">
    <TextBlock FontSize="12"
               TextWrapping="Wrap"
               Foreground="#B6CBD8"
               Text="{Binding}" />
  </DataTemplate>

  <DataTemplate x:Key="CookbookWorkspaceLineTemplate">
    <Border Margin="0,0,0,6"
            Padding="10,8"
            HorizontalAlignment="Stretch"
            Background="#101923"
            BorderBrush="#365063"
            BorderThickness="1"
            CornerRadius="6">
      <SelectableTextBlock TextWrapping="Wrap"
                           LineHeight="18"
                           Foreground="#D8EEF3"
                           Text="{Binding}" />
    </Border>
  </DataTemplate>

  <DataTemplate x:Key="CookbookWorkspaceStateLineTemplate">
    <Border Margin="0,0,0,6"
            Padding="10,8"
            HorizontalAlignment="Stretch"
            Background="#1A1714"
            BorderBrush="#8A6240"
            BorderThickness="1"
            CornerRadius="6"
            MaxHeight="88"
            ClipToBounds="True">
      <SelectableTextBlock TextWrapping="Wrap"
                           LineHeight="18"
                           Foreground="#F6D8B6"
                           Text="{Binding}" />
    </Border>
  </DataTemplate>
</ResourceDictionary>
