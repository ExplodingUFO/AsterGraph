<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <UsePackedAsterGraphPackages Condition="'$(UsePackedAsterGraphPackages)' == ''">false</UsePackedAsterGraphPackages>
    <LocalPackageFeed>$(MSBuildThisFileDirectory)..\..\artifacts\packages</LocalPackageFeed>
    <RestoreSources Condition="'$(UsePackedAsterGraphPackages)' == 'true'">$(LocalPackageFeed);$(RestoreSources)</RestoreSources>
  </PropertyGroup>

  <ItemGroup Condition="'$(UsePackedAsterGraphPackages)' == 'true'">
    <PackageReference Include="AsterGraph.Abstractions" Version="$(Version)" />
    <PackageReference Include="AsterGraph.Avalonia" Version="$(Version)" />
    <PackageReference Include="AsterGraph.Editor" Version="$(Version)" />
  </ItemGroup>

  <ItemGroup Condition="'$(UsePackedAsterGraphPackages)' != 'true'">
    <ProjectReference Include="..\..\src\AsterGraph.Abstractions\AsterGraph.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\AsterGraph.Avalonia\AsterGraph.Avalonia.csproj" />
    <ProjectReference Include="..\..\src\AsterGraph.Editor\AsterGraph.Editor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Headless" Version="11.3.10" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.10" />
  </ItemGroup>
</Project>
